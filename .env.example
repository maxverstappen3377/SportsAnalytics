# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/badminton
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/badminton

# Redis
REDIS_URL=redis://redis:6379/0
LOCAL_REDIS_URL=redis://localhost:6379/0

# Object Storage (MinIO / S3)
S3_BUCKET=badminton-videos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT_URL=http://object-store:9000
LOCAL_S3_ENDPOINT_URL=http://localhost:9000

# Auth & Secrets
JWT_SECRET=your_jwt_signing_secret_min_32_chars
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CV Model Paths
TRACKNET_WEIGHTS_PATH=backend/cv_worker/vendor/tracknetv3/weights/model.onnx
YOLO_WEIGHTS_PATH=yolov8n.onnx
BST_WEIGHTS_PATH=backend/cv_worker/vendor/bst/weights/bst.onnx

# Hardware configuration
FORCE_CPU=false
VRAM_LIMIT_MB=3500
